@page "/"

<PageTitle> Duel Tracker</PageTitle>



@implements IDisposable

<FluentStack Orientation="Orientation.Horizontal" Width="100%" Class="players" Style="flex-wrap:wrap;">

    <DuelTracker.Components.PlayerComponent @ref="Player1" PlayerName="Player 1" LifePoints="@InitialValue" />
    <DuelTracker.Components.PlayerComponent @ref="Player2" PlayerName="Player 2" LifePoints="@InitialValue" />

</FluentStack>

@code {

    public DuelTracker.Components.PlayerComponent? Player1 { get; set; }

    public DuelTracker.Components.PlayerComponent? Player2 { get; set; }

    public int InitialValue { get; set; } = 8000;

    private void Reset()
    {
        Player1?.Reset(InitialValue);
        Player2?.Reset(InitialValue);
    }

    [Inject]
    public DuelTracker.Services.AppActionsService? Actions { get; set; }

    [CascadingParameter]
    public DuelTracker.Services.AppState? AppState { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Actions?.ResetRequested += OnResetRequested;
        // Initialize players
        Player1?.Init(InitialValue);
        Player2?.Init(InitialValue);
    }

    private void OnResetRequested()
    {
        Reset();
        StateHasChanged();
    }

    public void Dispose()
    {
        Actions?.ResetRequested -= OnResetRequested;
    }

}
